-- SOLUÇÃO:

SELECT 
data_acesso,
UPPER(TRIM(nome_aluno)) AS nome_aluno,
COALESCE(plano_atual, 'Sem plano') AS plano
FROM frequencia f
INNER JOIN alunos a ON f.id_aluno = a.id_aluno;
