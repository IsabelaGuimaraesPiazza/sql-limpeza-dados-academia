-- SCHEMA:

CREATE TABLE alunos (
    id_aluno INT PRIMARY KEY,
    nome_aluno VARCHAR(100),
    plano_atual VARCHAR(50)
);

CREATE TABLE frequencia (
    id_acesso INT PRIMARY KEY,
    id_aluno INT,
    data_acesso DATE
);

